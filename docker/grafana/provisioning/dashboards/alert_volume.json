{
  "title": "TrustSOC — Alert Volume",
  "uid": "trustsoc-alerts",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Alerts per Hour (Last 24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "uid": "trustsoc_postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, count(*) AS alerts FROM alerts WHERE created_at >= now() - interval '24 hours' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Alerts by Status",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "uid": "trustsoc_postgres" },
      "targets": [
        {
          "rawSql": "SELECT status AS metric, count(*) AS value FROM alerts GROUP BY status ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Alerts by Source System",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "uid": "trustsoc_postgres" },
      "targets": [
        {
          "rawSql": "SELECT source_system AS metric, count(*) AS value FROM alerts GROUP BY source_system ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Risk Score Distribution",
      "type": "histogram",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "uid": "trustsoc_postgres" },
      "targets": [
        {
          "rawSql": "SELECT risk_score FROM alerts WHERE created_at >= now() - interval '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "High Risk Alerts (score >= 70)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "trustsoc_postgres" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS value FROM alerts WHERE risk_score >= 70 AND created_at >= now() - interval '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Alerts Today",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "trustsoc_postgres" },
      "options": { "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS value FROM alerts WHERE created_at >= now() - interval '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Open Incidents",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "trustsoc_postgres" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS value FROM incidents WHERE status = 'open'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "False Positive Rate (Last 24h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "trustsoc_postgres" },
      "options": { "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN count(*) = 0 THEN 0 ELSE round(100.0 * sum(CASE WHEN feedback_type = 'false_positive' THEN 1 ELSE 0 END) / count(*), 1) END AS value FROM feedback WHERE created_at >= now() - interval '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
