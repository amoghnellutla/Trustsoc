# TrustSOC Environment Configuration
# Copy this file to .env and fill in your values.
#
# REQUIRED (the only two values you must set):
DATABASE_URL=postgresql://user:password@localhost:5432/trustsoc
API_KEY=change_me_before_deploying

# OPTIONAL — Threat Intelligence APIs
# TrustSOC runs without these; alerts will use mock enrichment data.
# Get free keys at: https://www.virustotal.com | https://www.abuseipdb.com | https://otx.alienvault.com
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# OPTIONAL — LLM Investigation Narratives (Phase 2)
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OPTIONAL — Slack / Discord notifications (incoming webhook)
# Slack: https://api.slack.com/messaging/webhooks
# Discord: append /slack to your Discord webhook URL
SLACK_WEBHOOK_URL=

# OPTIONAL — Email digest (Gmail SMTP)
# Create an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_EMAIL_TO=

# OPTIONAL — Wazuh Active Response (real IP blocking)
WAZUH_API_URL=
WAZUH_API_USER=wazuh
WAZUH_API_PASS=

# OPTIONAL — pfSense/OPNsense firewall (real IP blocking)
PFSENSE_API_URL=
PFSENSE_API_KEY=

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Enrichment
ENRICHMENT_BUDGET_PER_ALERT_USD=0.10
ENRICHMENT_CACHE_TTL_SECONDS=3600

# Rate Limiting
MAX_ALERTS_PER_MINUTE=100
MAX_BLOCKS_PER_HOUR=50

# Safety — Automated Actions
AUTO_BLOCK_ENABLED=true
AUTO_BLOCK_DURATION_MINUTES=15
CRITICAL_ASSET_MIN_SCORE=8

# Risk Thresholds
HIGH_RISK_THRESHOLD=70
MEDIUM_RISK_THRESHOLD=40

# Correlation
CORRELATION_TIME_WINDOW_MINUTES=15
MIN_ALERTS_FOR_INCIDENT=3
